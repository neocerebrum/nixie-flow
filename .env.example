APP_ENV=dev
APP_DEBUG=true
APP_BASE_URL=http://localhost:8080

# Public URL of the app, used in outgoing email links and HTTPS detection.
# In prod set to https://your-domain. Falls back to scheme + HTTP_HOST if empty.
APP_URL=

# Force the Secure cookie flag and HTTPS detection regardless of $_SERVER.
# Set to true in prod when behind a TLS-terminating proxy.
APP_FORCE_HTTPS=false

# Comma-separated CIDRs of trusted reverse proxies. REQUIRED in prod when
# behind a proxy: without it, X-Forwarded-Proto / X-Forwarded-For are ignored
# and rate limits / Secure cookies use the proxy IP instead of the client IP.
# Example: TRUSTED_PROXIES=127.0.0.1/32,10.0.0.0/8,::1/128
TRUSTED_PROXIES=

# DB driver: sqlite | mysql (mysql works with MariaDB too)
DB_DRIVER=sqlite
DB_SQLITE_PATH=data/aquata.sqlite

# When DB_DRIVER=mysql, set:
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=aquata
# DB_USER=
# DB_PASS=

SESSION_NAME=aquata_sid
SESSION_LIFETIME=86400

# ── Self-service signup ───────────────────────────────────────────────────
# false (default) = only admins can create accounts (private/team installs).
# true  = public self-registration enabled; new accounts start as demo tier
#         (diagrams expire after 24 h) until an admin promotes them to full.
SIGNUP_ENABLED=false
REQUIRE_EMAIL_VERIFY=true

# ── Mailer ────────────────────────────────────────────────────────────────
# Transport: mail (PHP mail()) | smtp | log (writes data/mail/*.eml) | null
MAIL_TRANSPORT=mail
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Aquata

# When MAIL_TRANSPORT=smtp:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_ENCRYPTION=tls    # tls (STARTTLS) | ssl (port 465) | none
# SMTP_TIMEOUT=15
# SMTP_HELO=             # defaults to APP_URL host or "localhost"

# ── Per-user quotas (0 = unlimited; admins always bypass) ─────────────────
QUOTA_DIAGRAMS_PER_USER=100
QUOTA_REVISIONS_PER_DIAGRAM=500
QUOTA_BYTES_PER_USER=52428800

# ── Rate limits (requests per minute; 0 = unlimited) ──────────────────────
RATE_API_PER_IP_PER_MIN=600
RATE_API_PER_USER_PER_MIN=300
RATE_API_PER_TOKEN_PER_MIN=120
RATE_API_WRITE_PER_USER_PER_MIN=30
RATE_API_WRITE_PER_TOKEN_PER_MIN=30
RATE_MCP_PER_TOKEN_PER_MIN=120
RATE_MCP_WRITE_PER_TOKEN_PER_MIN=30
RATE_SIGNUP_PER_IP_PER_MIN=3
RATE_RESET_PER_IP_PER_MIN=3

# ── Login lockout (anti-brute-force) ──────────────────────────────────────
LOGIN_IP_FAILURE_LIMIT=10
LOGIN_EMAIL_FAILURE_LIMIT=10
LOGIN_FAILURE_WINDOW_SEC=900

# ── Security headers ──────────────────────────────────────────────────────
# HSTS: only sent over HTTPS. Default 180 days. Set HSTS_PRELOAD=true only when
# you've already submitted to the HSTS preload list.
HSTS_MAX_AGE=15552000
HSTS_PRELOAD=false
# Override the default CSP entirely. Leave empty to use the bundled default.
# CSP_POLICY=
# Send the policy in report-only mode (debug). Default false (enforced).
CSP_REPORT_ONLY=false

# ── MCP CORS ──────────────────────────────────────────────────────────────
# "*" = any origin (default; Bearer auth means cookies aren't at risk).
# Or comma-separated origins to allowlist exactly.
MCP_ALLOWED_ORIGINS=*
